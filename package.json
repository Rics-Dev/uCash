{
  "name": "uCash",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check": "oxlint",
    "dev": "turbo dev",
    "dev:prod": "NODE_ENV=production turbo dev",
    "build": "turbo build",
    "build:dev": "NODE_ENV=development turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @uCash/db db:push",
    "db:push:prod": "NODE_ENV=production turbo -F @uCash/db db:push",
    "db:studio": "turbo -F @uCash/db db:studio",
    "db:studio:prod": "NODE_ENV=production turbo -F @uCash/db db:studio",
    "db:generate": "turbo -F @uCash/db db:generate",
    "db:migrate": "turbo -F @uCash/db db:migrate"
  },
  "dependencies": {
    "@polar-sh/sdk": "^0.41.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "dotenv": "^17.2.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.4",
    "@types/node": "^22.13.11",
    "oxlint": "^1.12.0",
    "tsdown": "^0.15.5",
    "turbo": "^2.5.4",
    "ultracite": "6.3.2"
  },
  "packageManager": "pnpm@10.21.0"
}
